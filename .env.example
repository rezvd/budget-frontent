# Google Sheets API (read + append)
# Spreadsheet id from URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
VITE_GOOGLE_SHEET_ID=

# Example: Sheet1!A:F
# Columns expected by app: id, date, type, category, amount, note
VITE_GOOGLE_SHEET_RANGE=Sheet1!A:F

# API key with Google Sheets API enabled
VITE_GOOGLE_SHEETS_API_KEY=
