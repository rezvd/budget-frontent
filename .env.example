# Spreadsheet id from URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
VITE_GOOGLE_SHEET_ID=

# Range with your existing columns:
# A: дата, B: день, C: сумма, D: магазин, E: категория, F: комментарий
VITE_GOOGLE_SHEET_RANGE=logs!A:F

# API key with Google Sheets API enabled (read-only usage in frontend)
VITE_GOOGLE_SHEETS_API_KEY=
